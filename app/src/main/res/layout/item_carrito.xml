<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <!-- Icono -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardIcon"
            android:layout_width="52dp"
            android:layout_height="52dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/gray_100"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
            <ImageView
                android:id="@+id/ivIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="8dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_otros" />
        </androidx.cardview.widget.CardView>

        <!-- Nombre -->
        <TextView
            android:id="@+id/tvNombre"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:textColor="@color/gray_800"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppins_medium"
            android:includeFontPadding="false"
            android:ellipsize="end"
            android:maxLines="1"
            app:layout_constraintStart_toEndOf="@id/cardIcon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/cardIcon" />

        <!-- Precio unitario -->
        <TextView
            android:id="@+id/tvPrecioUnitario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:textColor="@color/gray_600"
            android:textSize="11sp"
            android:fontFamily="@font/poppins_regular"
            android:includeFontPadding="false"
            app:layout_constraintStart_toEndOf="@id/cardIcon"
            app:layout_constraintTop_toBottomOf="@id/tvNombre" />

        <!-- Controles cantidad -->
        <LinearLayout
            android:id="@+id/layoutCantidad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="12dp"
            android:layout_marginTop="8dp"
            app:layout_constraintStart_toEndOf="@id/cardIcon"
            app:layout_constraintTop_toBottomOf="@id/tvPrecioUnitario">

            <!-- Botón disminuir -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMenos"
                style="@style/ShopNova.Button.Secondary"
                android:layout_width="32dp"
                android:layout_height="32dp"
                app:icon="@drawable/ic_menos"
                app:iconGravity="textTop"
                app:iconPadding="11dp"
                android:textSize="16sp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="8dp" />

            <!-- Cantidad -->
            <TextView
                android:id="@+id/tvCantidad"
                android:layout_width="36dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/gray_800"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_medium"
                android:includeFontPadding="false" />

            <!-- Botón aumentar -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMas"
                style="@style/ShopNova.Button.Secondary"
                android:layout_width="32dp"
                android:layout_height="32dp"
                app:icon="@drawable/ic_add"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                android:textSize="16sp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="8dp" />

        </LinearLayout>

        <!-- Subtotal -->
        <TextView
            android:id="@+id/tvSubtotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/primary_blue"
            android:textSize="15sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppins_medium"
            android:includeFontPadding="false"
            app:layout_constraintEnd_toStartOf="@id/btnEliminar"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvNombre" />

        <!-- Botón eliminar -->
        <ImageButton
            android:id="@+id/btnEliminar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_delete"
            android:background="@android:color/transparent"
           android:backgroundTint="@color/error_red"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>